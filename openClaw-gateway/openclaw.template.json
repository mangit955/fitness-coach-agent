{
  "gateway": {
    "mode": "local",
    "port": __OPENCLAW_GATEWAY_PORT__,
    "bind": "lan",
    "auth": {
      "mode": "token",
      "token": "__OPENCLAW_GATEWAY_TOKEN__"
    },
    "http": {
      "endpoints": {
        "responses": {
          "enabled": true
        }
      }
    },
    "controlUi": {
      "enabled": false
    }
  },
  "agents": {
    "defaults": {
      "model": {
        "primary": "__OPENCLAW_PRIMARY_MODEL__"
      }
    }
  }
}
